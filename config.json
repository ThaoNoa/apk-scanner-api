{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "workers": 4,
    "timeout": 300
  },
  "mobsf": {
    "enabled": false,
    "url": "http://localhost:8000",
    "api_key": ""
  },
  "scanner": {
    "max_file_size_mb": 100,
    "temp_upload_dir": "C:\\ProgramData\\APKMalwareScanner\\uploads",
    "log_dir": "C:\\ProgramData\\APKMalwareScanner\\logs",
    "keep_temp_files": false,
    "scan_timeout_seconds": 300
  },
  "detection": {
    "risk_thresholds": {
      "critical": 70,
      "high": 50,
      "medium": 25,
      "low": 10
    },
    "voice_phishing": {
      "enabled": true,
      "detect_outgoing_hijacking": true,
      "detect_incoming_spoofing": true,
      "detect_call_log_manipulation": true
    },
    "permissions": {
      "critical_permissions": [
        "android.permission.INSTALL_PACKAGES",
        "android.permission.PROCESS_OUTGOING_CALLS"
      ],
      "high_risk_permissions": [
        "android.permission.READ_SMS",
        "android.permission.SEND_SMS",
        "android.permission.CAMERA",
        "android.permission.BIND_INCALL_SERVICE"
      ]
    }
  },
  "api": {
    "rate_limit": 100,
    "rate_limit_period_seconds": 60,
    "max_concurrent_scans": 5
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "C:\\ProgramData\\APKMalwareScanner\\logs\\scanner.log",
    "max_bytes": 10485760,
    "backup_count": 5
  }
}